# ============================================================
# THRIVE ONLINE PHARMACY — Environment Variables
# ============================================================
# Copy this file to backend/.env and fill in your values.
# Never commit the actual .env file to version control.

# ─────────────────────────────────────────────
# Backend — Server
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/thrive_pharmacy?schema=public"

# ─────────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_chars
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# Safaricom Daraja API (M-Pesa)
# Sandbox: https://developer.safaricom.co.ke
# ─────────────────────────────────────────────
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_daraja_consumer_key
MPESA_CONSUMER_SECRET=your_daraja_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# ─────────────────────────────────────────────
# Cloudinary (Image Storage)
# https://cloudinary.com
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─────────────────────────────────────────────
# Email (SMTP)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@thrivepharmacy.co.ke

# ─────────────────────────────────────────────
# Frontend — Vite
# (create frontend/.env with these)
# ─────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api
